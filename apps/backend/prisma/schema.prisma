generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id                 String   @id @default(cuid())

  fullName           String
  email              String   @unique
  phone              String?

  city               String?
  state              String?
  zip                String?

  currentCompany     String?
  currentRole        String?

  totalExperience    Int?
  noticePeriod       Int?

  assignedRecruiter  String?

  currentCTC         Float?
  expectedCTC        Float?

  technicalSkills    String[]

  resumeUrl          String?

  candidateNotes     String?

  status             String   @default("ACTIVE")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Job {
  id                     String    @id @default(cuid())

  // BASIC INFORMATION
  jobTitle               String
  clientCompany          String
  employmentType         String?
  priorityLevel          String?   @default("Medium")

  // TEAM & RECRUITER ASSIGNMENT
  assignedRecruiters     String[]

  // EXPERIENCE & COMPENSATION
  minExperience          Int?
  maxExperience          Int?

  minSalary              Float?
  maxSalary              Float?

  budgetCurrency         String?   @default("INR")

  targetOpenings         Int?      @default(1)

  // SKILLS & EDUCATION
  educationRequirement   String?

  requiredSkills         String[]

  // JOB DESCRIPTION
  jobDescription         String?

  // HIRING LOCATIONS
  locations              Json?

  // PUBLISHING SETTINGS
  requisitionStatus      String?   @default("Open")

  // PIPELINE METRICS
  pipelineCount          Int?      @default(0)
  hiredCount             Int?      @default(0)

  // SYSTEM
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}